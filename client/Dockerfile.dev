# Bifrost Client - Development Container Image
# Installs dependencies only - all code comes from volume mounts
# Prevents stale code and build cache issues

# node:20-slim
FROM node@sha256:f6f9fae352b319e817eec5efc7721b3f06bc53104f2f800d0f778f3915835804

WORKDIR /app

# Keep Debian package versions floating in the dev image so CI and local test
# stacks receive base-image security updates without routine pin churn.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        g++ \
        libcap2-bin \
        libsecret-1-dev \
        make \
        pkg-config \
        python3 \
    && rm -rf /var/lib/apt/lists/*

# Copy package files and install dependencies
COPY package*.json ./
RUN npm ci

RUN setcap 'cap_net_bind_service=+ep' "$(command -v node)" && \
    mkdir -p /app/node_modules/.vite && \
    chown node:node /app /app/node_modules/.vite

USER node

# Don't copy source code - it comes from volume mounts in docker-compose.dev.yml
# This prevents any risk of stale built code overwriting live source

ARG VITE_BIFROST_VERSION=unknown
ENV VITE_BIFROST_VERSION=${VITE_BIFROST_VERSION}

# Expose port 80 to match production nginx
EXPOSE 80

# Start Vite dev server with HMR
# --host 0.0.0.0 allows external connections (needed for Docker)
# --port 80 to match production nginx port
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "80"]
